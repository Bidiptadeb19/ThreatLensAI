# Optional AI provider. If absent, ThreatLens uses deterministic template explanations.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional threat intelligence integrations. The app works without these.
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=

# Scanner controls
SCAN_TIMEOUT_MS=5000
SCAN_MAX_REDIRECTS=5
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
